# .env
# Copy this file to '.env' and modify for production deployment.
# For local development, you do not need this file (it will use localhost defaults).

# --- GitHub Integration ---
# Used by the Orchestrator to fetch workflows and trigger them
GITHUB_TOKEN=ghp_your_actual_token_here
GITHUB_OWNER=mattDev0
GITHUB_REPO=portfolio-monorepo

# --- Grafana Security & Routing (Production specific) ---
# When hosting on a real domain with HTTPS, set these to ensure iframes load correctly.
DOMAIN=mattdev0.tech
GRAFANA_ROOT_URL=https://mattdev0.tech/devops/grafana/
COOKIE_SAMESITE=none
COOKIE_SECURE=true
