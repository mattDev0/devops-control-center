# .env
# Copy this file to '.env' and modify for production deployment.
# For local development, you do not need this file (it will use localhost defaults).

# --- GitHub Integration ---
# Used by the Orchestrator to fetch workflows and trigger them
GITHUB_TOKEN=ghp_your_actual_token_here
GITHUB_OWNER=mattDev0
GITHUB_REPO=portfolio-monorepo

# --- Grafana Security & Routing (Production specific) ---
# When hosting on a real domain with HTTPS, set these to ensure iframes load correctly.
DOMAIN=devops.mattdev0.tech
GRAFANA_ROOT_URL=https://devops.mattdev0.tech/grafana/
GRAFANA_ADMIN_PASSWORD=choose_a_strong_grafana_password_here
COOKIE_SAMESITE=none
COOKIE_SECURE=true

# --- Security configurations ---
# Secret token to secure communication between Java Backend and Rust Agent
AGENT_SECRET_KEY=generate_a_long_secure_random_key_here
# Admin credentials for UI Dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password_here
# Secret key for JWT signing (must be at least 32 characters / 256-bit key)
JWT_SECRET=generate_a_long_secure_random_string_here_at_least_32_chars
